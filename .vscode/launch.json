{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Python: Attach Debugger",
			"type": "debugpy",
			"request": "attach",
			"connect": {
				"host": "localhost",
				"port": 56789
			},
			"pathMappings": [
				{
					"localRoot": "${workspaceFolder}",
					"remoteRoot": "."
				}
			],
			"justMyCode": true
		}
	]
}
